# API Configuration
VITE_API_URL=http://localhost:5000/api

# For production, use your actual API URL
# VITE_API_URL=https://your-api-domain.com/api

# Email Service Configuration
# Choose your email service: smtp, sendgrid, ses, mailgun, brevo
VITE_EMAIL_SERVICE=sendgrid

# SMTP Configuration (if using SMTP)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_SECURE=true
VITE_SMTP_USER=your-email@gmail.com
VITE_SMTP_PASS=your-app-password

# SendGrid Configuration (if using SendGrid)
VITE_SENDGRID_API_KEY=your-sendgrid-api-key
VITE_SENDGRID_FROM=noreply@dyadpractice.com

# AWS SES Configuration (if using AWS SES)
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-key
VITE_AWS_REGION=us-east-1
VITE_SES_FROM=noreply@dyadpractice.com

# Mailgun Configuration (if using Mailgun)
VITE_MAILGUN_API_KEY=your-mailgun-api-key
VITE_MAILGUN_DOMAIN=your-domain.com
VITE_MAILGUN_FROM=noreply@dyadpractice.com

# Brevo (Sendinblue) Configuration (if using Brevo)
VITE_BREVO_API_KEY=your-brevo-api-key
VITE_BREVO_FROM=noreply@dyadpractice.com

# reCAPTCHA Configuration
VITE_RECAPTCHA_SITE_KEY=6LffdaksAAAAAHFjP8h_KlJscBo85SWBjcZ8Bgd1
RECAPTCHA_SECRET_KEY=your-secret-key-here
