# API
VITE_API_URL=http://localhost:5000/api

# Zoho Pay — embedded widget (client-safe)
VITE_ZOHO_PAY_ACCOUNT_ID=
VITE_ZOHO_PAY_API_KEY=
VITE_ZOHO_PAY_DOMAIN=US
# Set true only for UI demo without Zoho credentials
VITE_ZOHO_PAY_USE_MOCK=false

# Zoho Pay — server only (do NOT prefix with VITE_)
# ZOHO_PAY_ACCOUNT_ID=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_PAYMENTS_API_BASE=https://payments.zoho.com/api/v1
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
